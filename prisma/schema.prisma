// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- Enums ----

enum Role {
  ADMIN
  COUNSELOR
  ACCOUNTANT
  TRAINER
  EMITRA
}

enum InquiryStatus {
  NEW
  FOLLOWUP
  CONVERTED
  NOT_INTERESTED
}

enum InquirySource {
  GOOGLE
  WEBSITE
  WALK_IN
  REFERRAL
  SOCIAL_MEDIA
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CourseLevel {
  BASIC
  MODERATE
  ADVANCE
}

enum BatchPreference {
  MORNING
  AFTERNOON
  EVENING
}

enum BatchStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

// ---- Models ----

model User {
  id                String       @id @default(cuid())
  name              String
  email             String       @unique
  password          String
  role              Role         @default(COUNSELOR)
  phone             String?
  commissionRate    Float        @default(10) // Specific commission % for EMITRA users
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  inquiries         Inquiry[]    @relation("counselorInquiries")
  referredInquiries Inquiry[]    @relation("emitraInquiries")
  referrals         Student[]
  commissions       Commission[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Inquiry {
  id           String        @id @default(cuid())
  inquiryNo    Int           @unique @default(autoincrement())
  name         String
  mobile       String
  email        String?
  courseId      String?
  source       InquirySource @default(WALK_IN)
  status       InquiryStatus @default(NEW)
  followupDate DateTime?
  notes        String?
  counselorId  String?
  feeOffered   Float?
  referredById String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  course    Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  counselor User?    @relation(fields: [counselorId], references: [id], name: "counselorInquiries", onDelete: SetNull)
  referrer  User?    @relation(fields: [referredById], references: [id], name: "emitraInquiries", onDelete: SetNull)
  student   Student?

  @@index([status])
  @@index([mobile])
  @@index([counselorId])
  @@index([referredById])
  @@index([createdAt])
  @@map("inquiries")
}

model Student {
  id               String           @id @default(cuid())
  studentId        String           @unique @default(cuid())
  firstName        String
  lastName         String
  fatherName       String?
  motherName       String?
  dob              DateTime?
  gender           Gender?
  category         String?
  mobile           String
  whatsapp         String?
  email            String?
  address          String?
  city             String?
  state            String?
  pincode          String?
  parentName       String?
  parentOccupation String?
  parentMobile     String?
  aadhaarNumber    String?
  aadhaarUrl       String?
  photoUrl         String?
  courseId          String?
  batchId          String?
  courseLevel       CourseLevel?
  batchPreference  BatchPreference?
  admissionDate    DateTime         @default(now())
  isActive         Boolean          @default(true)
  inquiryId        String?          @unique
  referredById     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  course      Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  batch       Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  inquiry     Inquiry?     @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  referredBy  User?        @relation(fields: [referredById], references: [id], onDelete: SetNull)
  fee         Fee?
  attendance  Attendance[]
  certificate Certificate?
  commission  Commission?
  feeTransactions FeeTransaction[]

  @@index([mobile])
  @@index([courseId])
  @@index([batchId])
  @@index([referredById])
  @@index([isActive])
  @@index([admissionDate])
  @@map("students")
}

model Course {
  id          String   @id @default(cuid())
  name        String
  duration    String
  fee         Float
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  batches      Batch[]
  students     Student[]
  inquiries    Inquiry[]
  certificates Certificate[]

  @@map("courses")
}

model Batch {
  id        String      @id @default(cuid())
  courseId   String
  batchName String
  trainer   String
  startTime String
  endTime   String
  startDate DateTime?
  status    BatchStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  students   Student[]
  attendance Attendance[]

  @@index([courseId])
  @@index([status])
  @@map("batches")
}

model Fee {
  id          String    @id @default(cuid())
  studentId   String    @unique
  totalFee    Float
  discount    Float     @default(0)
  finalFee    Float
  paidAmount  Float     @default(0)
  dueAmount   Float
  nextDueDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  transactions FeeTransaction[]

  @@map("fees")
}

model FeeTransaction {
  id            String      @id @default(cuid())
  feeId         String
  studentId     String
  amount           Float
  paymentMode      PaymentMode @default(CASH)
  receiptNumber    String      @unique @default(cuid())
  offlineReceiptNo String?
  paymentDate      DateTime    @default(now())
  notes         String?
  createdAt     DateTime    @default(now())

  fee     Fee     @relation(fields: [feeId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeId])
  @@index([paymentDate])
  @@map("fee_transactions")
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  batchId   String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId, date])
  @@index([batchId, date])
  @@map("attendance")
}

model Certificate {
  id             String   @id @default(cuid())
  studentId      String   @unique
  courseId       String
  completionDate DateTime
  certificateNo  String   @unique @default(cuid())
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Commission {
  id            String           @id @default(cuid())
  studentId     String           @unique
  userId        String // e-Mitra / pointed center user ID
  amount        Float
  percentage    Float            @default(10) // Commission percentage (default 10%)
  status        CommissionStatus @default(PENDING)
  notes         String?
  paidAt        DateTime?
  paymentMode   PaymentMode?
  transactionId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studentId])
  @@index([status])
  @@map("commissions")
}

model Setting {
  id             String   @id @default("global") // Single row pattern
  instituteName  String   @default("Aaroh Institute")
  registrationNo String?
  phone          String?
  email          String?
  address        String?
  currency       String   @default("INR")
  timezone       String   @default("IST")
  twoFactor      Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@map("settings")
}
